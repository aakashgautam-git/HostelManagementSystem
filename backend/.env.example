# Copy this file to ".env" and fill in your local MySQL credentials.

# Django / JWT secrets (use any long random strings)
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
JWT_SECRET=change-me-to-another-long-random-string
DEBUG=True

# MySQL connection (must match the database created by /database/*.sql)
DB_NAME=hostel_db
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_HOST=127.0.0.1
DB_PORT=3306

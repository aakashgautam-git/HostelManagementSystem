// ER / schema diagram for the Hostel & Mess Management System.
// Render:  dot -Tpng schema_diagram.dot -o schema_diagram.png
digraph hostel_schema {
  graph [rankdir=LR, nodesep=0.5, ranksep=1.1, bgcolor="white",
         fontname="Helvetica", splines=ortho, pad=0.3];
  node  [shape=plaintext, fontname="Helvetica"];
  edge  [color="#475569", arrowhead=crow, arrowtail=none, dir=both, penwidth=1.3];

  admins [label=<
    <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
      <TR><TD COLSPAN="2" BGCOLOR="#0f766e"><FONT COLOR="white" POINT-SIZE="14"><B>admins</B></FONT></TD></TR>
      <TR><TD BGCOLOR="#ccfbf1"><B>PK</B></TD><TD PORT="pk" ALIGN="LEFT" BGCOLOR="#ccfbf1"><B>admin_id</B>  INT</TD></TR>
      <TR><TD></TD><TD ALIGN="LEFT">name  VARCHAR</TD></TR>
      <TR><TD>UK</TD><TD ALIGN="LEFT">email  VARCHAR</TD></TR>
      <TR><TD></TD><TD ALIGN="LEFT">password_hash</TD></TR>
    </TABLE>>];

  students [label=<
    <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
      <TR><TD COLSPAN="2" BGCOLOR="#4f46e5"><FONT COLOR="white" POINT-SIZE="14"><B>students</B></FONT></TD></TR>
      <TR><TD BGCOLOR="#eef2ff"><B>PK</B></TD><TD PORT="pk" ALIGN="LEFT" BGCOLOR="#eef2ff"><B>student_id</B>  INT</TD></TR>
      <TR><TD></TD><TD ALIGN="LEFT">name  VARCHAR</TD></TR>
      <TR><TD>UK</TD><TD ALIGN="LEFT">email  VARCHAR</TD></TR>
      <TR><TD></TD><TD ALIGN="LEFT">password_hash</TD></TR>
      <TR><TD></TD><TD ALIGN="LEFT">phone, gender, course</TD></TR>
      <TR><TD></TD><TD ALIGN="LEFT">year_of_study  INT</TD></TR>
      <TR><TD></TD><TD ALIGN="LEFT">balance  DECIMAL  (&#8805; 0)</TD></TR>
    </TABLE>>];

  rooms [label=<
    <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
      <TR><TD COLSPAN="2" BGCOLOR="#b45309"><FONT COLOR="white" POINT-SIZE="14"><B>rooms</B></FONT></TD></TR>
      <TR><TD BGCOLOR="#fef3c7"><B>PK</B></TD><TD PORT="pk" ALIGN="LEFT" BGCOLOR="#fef3c7"><B>room_id</B>  INT</TD></TR>
      <TR><TD>UK</TD><TD ALIGN="LEFT">room_number  VARCHAR</TD></TR>
      <TR><TD></TD><TD ALIGN="LEFT">block, floor, room_type</TD></TR>
      <TR><TD></TD><TD ALIGN="LEFT">capacity  INT  (&gt; 0)</TD></TR>
      <TR><TD></TD><TD ALIGN="LEFT">available_beds  INT</TD></TR>
      <TR><TD></TD><TD ALIGN="LEFT">monthly_rent  DECIMAL</TD></TR>
      <TR><TD></TD><TD ALIGN="LEFT">status  ENUM</TD></TR>
    </TABLE>>];

  room_allocations [label=<
    <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
      <TR><TD COLSPAN="2" BGCOLOR="#334155"><FONT COLOR="white" POINT-SIZE="14"><B>room_allocations</B></FONT></TD></TR>
      <TR><TD BGCOLOR="#e2e8f0"><B>PK</B></TD><TD ALIGN="LEFT" BGCOLOR="#e2e8f0"><B>allocation_id</B>  INT</TD></TR>
      <TR><TD>FK</TD><TD PORT="student" ALIGN="LEFT">student_id  INT</TD></TR>
      <TR><TD>FK</TD><TD PORT="room" ALIGN="LEFT">room_id  INT</TD></TR>
      <TR><TD></TD><TD ALIGN="LEFT">allocated_on, vacated_on</TD></TR>
      <TR><TD></TD><TD ALIGN="LEFT">status  ENUM</TD></TR>
    </TABLE>>];

  meal_bookings [label=<
    <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
      <TR><TD COLSPAN="2" BGCOLOR="#334155"><FONT COLOR="white" POINT-SIZE="14"><B>meal_bookings</B></FONT></TD></TR>
      <TR><TD BGCOLOR="#e2e8f0"><B>PK</B></TD><TD ALIGN="LEFT" BGCOLOR="#e2e8f0"><B>booking_id</B>  INT</TD></TR>
      <TR><TD>FK</TD><TD PORT="student" ALIGN="LEFT">student_id  INT</TD></TR>
      <TR><TD></TD><TD ALIGN="LEFT">meal_date  DATE</TD></TR>
      <TR><TD></TD><TD ALIGN="LEFT">meal_type  ENUM</TD></TR>
      <TR><TD></TD><TD ALIGN="LEFT">price  DECIMAL</TD></TR>
      <TR><TD></TD><TD ALIGN="LEFT">status  ENUM</TD></TR>
    </TABLE>>];

  fines [label=<
    <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
      <TR><TD COLSPAN="2" BGCOLOR="#334155"><FONT COLOR="white" POINT-SIZE="14"><B>fines</B></FONT></TD></TR>
      <TR><TD BGCOLOR="#e2e8f0"><B>PK</B></TD><TD ALIGN="LEFT" BGCOLOR="#e2e8f0"><B>fine_id</B>  INT</TD></TR>
      <TR><TD>FK</TD><TD PORT="student" ALIGN="LEFT">student_id  INT</TD></TR>
      <TR><TD></TD><TD ALIGN="LEFT">reason  VARCHAR</TD></TR>
      <TR><TD></TD><TD ALIGN="LEFT">amount  DECIMAL</TD></TR>
      <TR><TD></TD><TD ALIGN="LEFT">status  ENUM</TD></TR>
    </TABLE>>];

  bills [label=<
    <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
      <TR><TD COLSPAN="2" BGCOLOR="#be123c"><FONT COLOR="white" POINT-SIZE="14"><B>bills</B></FONT></TD></TR>
      <TR><TD BGCOLOR="#ffe4e6"><B>PK</B></TD><TD PORT="pk" ALIGN="LEFT" BGCOLOR="#ffe4e6"><B>bill_id</B>  INT</TD></TR>
      <TR><TD>FK</TD><TD PORT="student" ALIGN="LEFT">student_id  INT</TD></TR>
      <TR><TD></TD><TD ALIGN="LEFT">bill_month  DATE</TD></TR>
      <TR><TD></TD><TD ALIGN="LEFT">rent_amount, mess_amount</TD></TR>
      <TR><TD></TD><TD ALIGN="LEFT">fine_amount  DECIMAL</TD></TR>
      <TR><TD></TD><TD ALIGN="LEFT">total_amount  (GENERATED)</TD></TR>
      <TR><TD></TD><TD ALIGN="LEFT">paid_amount, status</TD></TR>
    </TABLE>>];

  payments [label=<
    <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
      <TR><TD COLSPAN="2" BGCOLOR="#334155"><FONT COLOR="white" POINT-SIZE="14"><B>payments</B></FONT></TD></TR>
      <TR><TD BGCOLOR="#e2e8f0"><B>PK</B></TD><TD ALIGN="LEFT" BGCOLOR="#e2e8f0"><B>payment_id</B>  INT</TD></TR>
      <TR><TD>FK</TD><TD PORT="student" ALIGN="LEFT">student_id  INT</TD></TR>
      <TR><TD>FK</TD><TD PORT="bill" ALIGN="LEFT">bill_id  INT  (NULL)</TD></TR>
      <TR><TD></TD><TD ALIGN="LEFT">amount  DECIMAL</TD></TR>
      <TR><TD></TD><TD ALIGN="LEFT">method  ENUM</TD></TR>
      <TR><TD></TD><TD ALIGN="LEFT">payment_date</TD></TR>
    </TABLE>>];

  complaints [label=<
    <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
      <TR><TD COLSPAN="2" BGCOLOR="#334155"><FONT COLOR="white" POINT-SIZE="14"><B>complaints</B></FONT></TD></TR>
      <TR><TD BGCOLOR="#e2e8f0"><B>PK</B></TD><TD ALIGN="LEFT" BGCOLOR="#e2e8f0"><B>complaint_id</B>  INT</TD></TR>
      <TR><TD>FK</TD><TD PORT="student" ALIGN="LEFT">student_id  INT</TD></TR>
      <TR><TD></TD><TD ALIGN="LEFT">category, subject</TD></TR>
      <TR><TD></TD><TD ALIGN="LEFT">description  TEXT</TD></TR>
      <TR><TD></TD><TD ALIGN="LEFT">status  ENUM</TD></TR>
      <TR><TD></TD><TD ALIGN="LEFT">created_at, resolved_at</TD></TR>
    </TABLE>>];

  // Foreign-key relationships (crow's foot = the "many" side)
  students:pk -> room_allocations:student [xlabel="1 : N"];
  rooms:pk    -> room_allocations:room;
  students:pk -> meal_bookings:student;
  students:pk -> fines:student;
  students:pk -> bills:student;
  students:pk -> payments:student;
  bills:pk    -> payments:bill;
  students:pk -> complaints:student;
}
